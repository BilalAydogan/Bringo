APP_SECRET="change-me-to-a-long-random-string"
DEFAULT_URI="https://app.example.com"

DATABASE_URL="postgresql://app:change-me@postgres:5432/app?serverVersion=16&charset=utf8"
REDIS_URL="redis://redis:6379"
MAILER_DSN="smtp://user:password@mail.example.com:587"

POSTGRES_USER="app"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="app"

JWT_SECRET_KEY="/var/www/html/config/jwt/private.pem"
JWT_PUBLIC_KEY="/var/www/html/config/jwt/public.pem"
JWT_PASSPHRASE="change-me"

VITE_API_URL="/api"
FRONTEND_PORT="80"
